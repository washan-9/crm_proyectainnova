# Copia este archivo como .env.local y completa los valores.
# Los encuentras en: Supabase Dashboard > tu proyecto > Settings > API Keys

# URL del proyecto de Supabase (ej. https://xxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Clave pública (anon / publishable key) del proyecto
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clave service_role (Settings > API Keys > service_role). SOLO se usa en el
# servidor para crear/inhabilitar empleados desde la pantalla de Gestión de
# Equipo. NUNCA la expongas con prefijo NEXT_PUBLIC_ ni la subas al repo.
SUPABASE_SERVICE_ROLE_KEY=
