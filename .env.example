# Copia este archivo como .env.local y completa los valores.
# Los encuentras en: Supabase Dashboard > tu proyecto > Settings > API Keys

# URL del proyecto de Supabase (ej. https://xxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Clave pública (anon / publishable key) del proyecto
NEXT_PUBLIC_SUPABASE_ANON_KEY=
